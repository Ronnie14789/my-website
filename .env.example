# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# For local development (no auth):
MONGO_URI=mongodb://localhost:27017/ecatu_portfolio

# For Docker Compose:
# MONGO_URI=******mongo:27017/ecatu_portfolio?authSource=admin

# Docker Compose credentials
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=changeme

# ─── JWT ──────────────────────────────────────────────────────────────────────
# IMPORTANT: Change this to a strong random secret in production
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:80

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
