<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>New Blog Post</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background-color: #0f172a; color: #e2e8f0; }
    .container { max-width: 600px; margin: 0 auto; padding: 20px; }
    .header { background: linear-gradient(135deg, #7c3aed, #1e40af); padding: 40px 30px; border-radius: 12px 12px 0 0; text-align: center; }
    .header h1 { color: #ffffff; font-size: 24px; }
    .header p { color: #ddd6fe; margin-top: 8px; }
    .body { background-color: #1e293b; padding: 40px 30px; border-radius: 0 0 12px 12px; }
    .post-image { width: 100%; border-radius: 8px; margin-bottom: 20px; }
    .post-title { font-size: 22px; font-weight: 700; color: #f1f5f9; margin-bottom: 12px; }
    .post-excerpt { color: #94a3b8; line-height: 1.7; margin-bottom: 24px; }
    .cta-button { display: inline-block; background: linear-gradient(135deg, #7c3aed, #1e40af); color: #ffffff !important; padding: 14px 32px; border-radius: 8px; text-decoration: none; font-weight: 600; }
    .footer { text-align: center; margin-top: 30px; color: #475569; font-size: 12px; }
    .footer a { color: #64748b; text-decoration: underline; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>📝 New Post Published!</h1>
      <p>Hi {{name}}, there's something new for you to read</p>
    </div>
    <div class="body">
      {{#if featuredImage}}<img src="{{featuredImage}}" alt="{{postTitle}}" class="post-image">{{/if}}
      <h2 class="post-title">{{postTitle}}</h2>
      <p class="post-excerpt">{{postExcerpt}}</p>
      <a href="{{postUrl}}" class="cta-button">Read Full Post →</a>
      <div class="footer">
        <p>© {{year}} Ecatu Ronald. All rights reserved.</p>
        <p style="margin-top:8px"><a href="{{unsubscribeUrl}}">Unsubscribe</a></p>
      </div>
    </div>
  </div>
</body>
</html>
